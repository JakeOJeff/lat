

color = {0.5,0.5,0.5}

call love.load()
    thing_item = {
        "wow", 2, "glim glim", place
    }
    print("hello")

    thing_item.place = 4
    
done

call love.update(dt)
    if -K:isDown("e")
        color = {1,1,1}
    done
done


call love.draw()
    -G:setColor(color)
    each k, v as t 
        print("hello")
    done
    -G:print(thing_item[1])
done