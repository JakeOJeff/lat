

color = {0.5,0.5,0.5}

call love.load()
    thing_item = {
        "Manan", "is my", "number", 1, "Press 'E' to change Color"
    }
    print("hello")
    
done

call love.update(dt)
    if -K:isDown("e")
        color = {0,1,0}
    else
        color = {0.5,0.5,0.5}
    done
done


call love.draw()
    -G:setColor(color)
    -G:setNewFont(35)
    seq i, v as thing_item
        -G:print(v, 20, i * 45)
    done
done